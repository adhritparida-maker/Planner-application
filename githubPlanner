        function updateDashboard() {
            const allTasks = loadAllTasks().filter(task => !task.completed);
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const endOfWeek = new Date(today);
            endOfWeek.setDate(endOfWeek.getDate() + 6);

            const dueToday = allTasks.filter(task => {
                if (!task.dueDate) return false;
                const due = parseLocalDate(task.dueDate);
                due.setHours(0, 0, 0, 0);
                return due.getTime() === today.getTime();
            }).length;

            const dueThisWeek = allTasks.filter(task => {
                if (!task.dueDate) return false;
                const due = parseLocalDate(task.dueDate);
                due.setHours(0, 0, 0, 0);
                return due.getTime() >= today.getTime() && due.getTime() <= endOfWeek.getTime();
            }).length;

            const overdue = allTasks.filter(task => {
                if (!task.dueDate) return false;
                const due = parseLocalDate(task.dueDate);
                due.setHours(0, 0, 0, 0);
                return due.getTime() < today.getTime();
            }).length;

            document.getElementById("countToday").textContent = dueToday;
            document.getElementById("countWeek").textContent = dueThisWeek;
            document.getElementById("countOverdue").textContent = overdue;
            updateHomeReminderSummary();
        }

