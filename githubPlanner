<!DOCTYPE html>
<html>
<head>
    <title>Planner App</title>
    <link rel="icon" type="image/png" href="Screenshot 2026-06-17 215154.png">
    <style>
        :root {
            --theme-primary: #2563eb;
            --theme-primary-dark: #1d4ed8;
            --theme-primary-light: #60a5fa;
            --theme-soft: #eff6ff;
            --theme-soft-strong: #dbeafe;
            --theme-tab: #f3f7ff;
            --theme-border: #cfe0ff;
            --theme-shadow: rgba(37, 99, 235, 0.16);
            --theme-on-primary: #ffffff;
        }

        body.theme-red { --theme-primary: #dc2626; --theme-primary-dark: #991b1b; --theme-primary-light: #f87171; --theme-soft: #fef2f2; --theme-soft-strong: #fecaca; --theme-tab: #fff1f2; --theme-border: #fecaca; --theme-shadow: rgba(220, 38, 38, 0.16); }
        body.theme-orange { --theme-primary: #ea580c; --theme-primary-dark: #9a3412; --theme-primary-light: #fb923c; --theme-soft: #fff7ed; --theme-soft-strong: #fed7aa; --theme-tab: #fff7ed; --theme-border: #fed7aa; --theme-shadow: rgba(234, 88, 12, 0.16); }
        body.theme-yellow { --theme-primary: #ca8a04; --theme-primary-dark: #854d0e; --theme-primary-light: #facc15; --theme-soft: #fefce8; --theme-soft-strong: #fde68a; --theme-tab: #fefce8; --theme-border: #fde68a; --theme-shadow: rgba(202, 138, 4, 0.16); }
        body.theme-green { --theme-primary: #16a34a; --theme-primary-dark: #166534; --theme-primary-light: #4ade80; --theme-soft: #f0fdf4; --theme-soft-strong: #bbf7d0; --theme-tab: #f0fdf4; --theme-border: #bbf7d0; --theme-shadow: rgba(22, 163, 74, 0.16); }
        body.theme-blue { --theme-primary: #2563eb; --theme-primary-dark: #1d4ed8; --theme-primary-light: #60a5fa; --theme-soft: #eff6ff; --theme-soft-strong: #dbeafe; --theme-tab: #f3f7ff; --theme-border: #cfe0ff; --theme-shadow: rgba(37, 99, 235, 0.16); }
        body.theme-purple { --theme-primary: #7c3aed; --theme-primary-dark: #5b21b6; --theme-primary-light: #a78bfa; --theme-soft: #f5f3ff; --theme-soft-strong: #ddd6fe; --theme-tab: #f5f3ff; --theme-border: #ddd6fe; --theme-shadow: rgba(124, 58, 237, 0.16); }
        body.theme-pink { --theme-primary: #db2777; --theme-primary-dark: #9d174d; --theme-primary-light: #f472b6; --theme-soft: #fdf2f8; --theme-soft-strong: #fbcfe8; --theme-tab: #fdf2f8; --theme-border: #fbcfe8; --theme-shadow: rgba(219, 39, 119, 0.16); }
        body.theme-black { --theme-primary: #111827; --theme-primary-dark: #030712; --theme-primary-light: #4b5563; --theme-soft: #f3f4f6; --theme-soft-strong: #d1d5db; --theme-tab: #f9fafb; --theme-border: #d1d5db; --theme-shadow: rgba(17, 24, 39, 0.16); }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, sans-serif;
            background: white;
            color: #1f2937;
            display: flex;
            justify-content: stretch;
            align-items: stretch;
            padding: 0;
        }

        .page-container {
            width: 100%;
            max-width: none;
            height: 100vh;
            background: white;
            border-radius: 0;
            box-shadow: none;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .header {
            background: linear-gradient(90deg, var(--theme-primary-dark), var(--theme-primary-light));
            padding: 16px 24px;
            color: white;
            text-align: center;
        }

        .header h1 {
            margin: 0;
            font-size: 1.5rem;
            letter-spacing: 0.02em;
        }

        .header p {
            margin: 4px 0 0;
            opacity: 0.85;
            font-size: 0.9rem;
        }

        .content {
            padding: 0 24px 24px 24px;
            flex: 1;
            overflow-y: auto;
        }

        .tab-bar {
            display: none;
            gap: 10px;
            justify-content: center;
            margin-bottom: 22px;
        }

        .major-tab-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 12px 18px;
            background: linear-gradient(90deg,#f8fbff,#ffffff);
            border-bottom: 1px solid #e6eefc;
        }

        .major-tabs {
            display: flex;
            gap: 10px;
        }

        .major-tab-button {
            padding: 12px 18px;
            border-radius: 14px;
            background: #f3f7ff;
            color: #1f2937;
            font-weight: 800;
            border: 1px solid transparent;
            cursor: pointer;
        }

        .major-tab-button.active {
            background: white;
            color: var(--theme-primary-dark);
            border-color: var(--theme-border);
            box-shadow: 0 8px 18px var(--theme-shadow);
        }

        .major-controls {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .major-controls button {
            position: relative;
        }

        .major-controls button .indicator {
            position: absolute;
            top: -2px;
            right: -2px;
            width: 8px;
            height: 8px;
            background: #ef4444;
            border-radius: 50%;
            display: none;
        }

        .major-controls button.has-indicator .indicator {
            display: block;
        }

        .sub-tab-bar {
            display: flex;
            gap: 10px;
            justify-content: flex-start;
            margin: 14px 0 22px 0;
            padding: 0 18px;
        }

        .sub-tab-button {
            padding: 10px 14px;
            border-radius: 12px;
            background: #f3f7ff;
            color: #1f2937;
            border: 1px solid transparent;
            font-weight: 700;
            cursor: pointer;
        }

        .sub-tab-button.active {
            background: white;
            color: var(--theme-primary-dark);
            border-color: var(--theme-border);
        }

        .tab-button {
            flex: 1;
            padding: 12px 16px;
            border: 1px solid transparent;
            background: #f3f7ff;
            color: #1f2937;
            border-radius: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s, border-color 0.2s, color 0.2s;
        }

        .tab-button.active {
            background: white;
            color: #1d4ed8;
            border-color: #cfe0ff;
            box-shadow: 0 8px 18px rgba(47, 107, 255, 0.12);
        }

        .task-box {
            border: 1px solid #e5efff;
            background: #f8fbff;
            border-radius: 22px;
            padding: 24px;
            min-height: 360px;
        }

        .task-box-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 18px;
        }

        .task-box-header h2 {
            margin: 0;
            font-size: 1.15rem;
        }

        .button-primary {
            padding: 12px 18px;
            border: none;
            border-radius: 14px;
            background: var(--theme-primary);
            color: var(--theme-on-primary);
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .button-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 18px var(--theme-shadow);
        }

        #taskList {
            list-style: none;
            padding: 0;
            margin: 0;
            display: grid;
            gap: 14px;
        }

        .task-item {
            padding: 18px 18px 18px 18px;
            border-radius: 18px;
            background: white;
            border: 1px solid #dee7ff;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
        }

        .task-details {
            flex: 1;
            min-width: 0;
        }

        .task-title {
            margin: 0 0 6px;
            font-size: 1rem;
            font-weight: 600;
            color: #111827;
            word-break: break-word;
        }

        .task-meta {
            margin: 0;
            color: #475569;
            font-size: 0.92rem;
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

        .task-meta span {
            background: #eff6ff;
            border-radius: 999px;
            padding: 4px 10px;
        }

        .task-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .task-actions button {
            background: #f8fafc;
            border: 1px solid #d1d5db;
            color: #1f2937;
            border-radius: 12px;
            padding: 10px 12px;
            cursor: pointer;
            transition: background 0.2s;
        }

        .task-actions button:hover {
            background: #eef2ff;
        }

        .tab-view {
            display: none;
        }

        .tab-view.active {
            display: block;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(160px, 1fr));
            gap: 18px;
        }

        .dashboard-card {
            background: #f8fbff;
            border: 1px solid #dbeafe;
            border-radius: 20px;
            padding: 22px;
            box-shadow: 0 10px 24px rgba(37, 99, 235, 0.08);
        }

        .dashboard-card h3 {
            margin: 0 0 14px;
            font-size: 0.95rem;
            color: #475569;
            font-weight: 700;
        }

        .dashboard-card p {
            margin: 0;
            font-size: 2.1rem;
            color: #1d4ed8;
            font-weight: 800;
        }

        .calendar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 18px;
            flex-wrap: wrap;
        }

        .calendar-header-controls {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 12px;
        }

        .holiday-toggle {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.92rem;
            color: #475569;
            font-weight: 600;
            cursor: pointer;
            user-select: none;
        }

        .holiday-toggle input {
            width: 16px;
            height: 16px;
            cursor: pointer;
        }

        .calendar-navigation {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .calendar-navigation button {
            padding: 12px 16px;
            border: 1px solid #cbd5e1;
            background: white;
            border-radius: 14px;
            cursor: pointer;
            font-weight: 600;
        }

        .calendar-month-label {
            min-width: 160px;
            text-align: center;
            font-weight: 800;
            color: var(--theme-primary-dark);
            font-size: 1.05rem;
        }

        .calendar-weekdays {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 10px;
            margin-bottom: 10px;
        }

        .calendar-weekday {
            text-align: center;
            color: #475569;
            font-weight: 700;
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 10px;
        }

        .calendar-day {
            min-height: 100px;
            border-radius: 18px;
            background: white;
            border: 1px solid #dbeafe;
            padding: 12px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            cursor: pointer;
            transition: transform 0.2s, border-color 0.2s;
        }

        .calendar-day:hover {
            transform: translateY(-1px);
            border-color: #93c5fd;
        }

        .calendar-day.other-month {
            opacity: 0.45;
        }

        .calendar-day.selected {
            border-color: var(--theme-primary);
            background: var(--theme-soft);
        }

        .calendar-day.today {
            border-color: #dc2626;
            background: #fef2f2;
        }

        .calendar-day.today .calendar-day-number::after {
            content: " ●";
            color: #dc2626;
            font-size: 0.6rem;
        }

        .calendar-day-number {
            font-weight: 700;
            margin-bottom: 8px;
            color: #111827;
        }

        .day-modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.7);
            display: none;
            justify-content: center;
            align-items: center;
            padding: 24px;
            z-index: 20;
        }

        .day-modal-backdrop.active {
            display: flex;
        }

        .day-modal-card {
            width: min(500px, 100%);
            background: white;
            border-radius: 24px;
            padding: 32px;
            box-shadow: 0 28px 80px rgba(15, 23, 42, 0.25);
            max-height: 80vh;
            overflow-y: auto;
        }

        .day-modal-card h2 {
            margin: 0 0 24px;
            font-size: 1.5rem;
            color: #0f172a;
        }

        .day-modal-close {
            position: absolute;
            top: 16px;
            right: 16px;
            background: #f1f5f9;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }

        .day-modal-close:hover {
            background: #e2e8f0;
        }

        .notes-editor {
            width: 100%;
            min-height: 400px;
            padding: 16px;
            border: 1px solid #cbd5e1;
            border-radius: 14px;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            font-size: 0.98rem;
            resize: vertical;
            outline: none;
            transition: border-color 0.2s;
        }

        .notes-editor:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

        .notes-status {
            margin-top: 10px;
            font-size: 0.85rem;
            color: #64748b;
            text-align: right;
        }

        .notes-status.saving {
            color: #f59e0b;
        }

        .notes-status.saved {
            color: #10b981;
        }

        .calendar-task-badge {
            margin-top: auto;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 6px 10px;
            border-radius: 999px;
            background: var(--theme-soft-strong);
            color: var(--theme-primary-dark);
            font-size: 0.85rem;
            font-weight: 700;
        }

        .calendar-day-badges {
            display: flex;
            flex-direction: column;
            gap: 6px;
            margin-top: auto;
        }

        .calendar-holiday-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 5px 8px;
            border-radius: 999px;
            background: #fef3c7;
            color: #92400e;
            font-size: 0.75rem;
            font-weight: 700;
            text-align: center;
            line-height: 1.2;
        }

        .calendar-holiday-label {
            background: #fef3c7;
            color: #92400e;
            font-size: 0.85rem;
            padding: 6px 10px;
            border-radius: 999px;
            white-space: nowrap;
        }

        .calendar-task-row.holiday-row {
            background: #fffbeb;
            border-color: #fde68a;
        }

        .theme-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 8px;
        }

        .theme-option {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            padding: 12px 8px;
            border: 2px solid transparent;
            border-radius: 16px;
            background: #f8fafc;
            cursor: pointer;
            transition: border-color 0.2s, transform 0.2s;
        }

        .theme-option:hover {
            transform: translateY(-1px);
        }

        .theme-option.selected {
            border-color: var(--theme-primary);
            background: var(--theme-soft);
        }

        .theme-swatch {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: 2px solid rgba(255, 255, 255, 0.9);
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
        }

        .theme-swatch-red { background: #dc2626; }
        .theme-swatch-orange { background: #ea580c; }
        .theme-swatch-yellow { background: #ca8a04; }
        .theme-swatch-green { background: #16a34a; }
        .theme-swatch-blue { background: #2563eb; }
        .theme-swatch-purple { background: #7c3aed; }
        .theme-swatch-pink { background: #db2777; }
        .theme-swatch-black { background: #111827; }

        .theme-option-label {
            font-size: 0.85rem;
            font-weight: 700;
            color: #334155;
            text-transform: capitalize;
        }

        .calendar-task-list {
            margin-top: 22px;
            padding: 18px 20px;
            border-radius: 20px;
            background: #f8fbff;
            border: 1px solid #dbeafe;
        }

        .calendar-task-list h3 {
            margin: 0 0 14px;
            font-size: 1.05rem;
        }

        .calendar-task-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 16px;
            background: white;
            border: 1px solid #dbeafe;
            margin-bottom: 10px;
        }

        .calendar-task-label {
            background: #eff6ff;
            color: #1d4ed8;
            font-size: 0.85rem;
            padding: 6px 10px;
            border-radius: 999px;
            white-space: nowrap;
        }

        .task-title.completed {
            text-decoration: line-through;
            color: #64748b;
        }

        .modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.5);
            display: none;
            justify-content: center;
            align-items: center;
            padding: 24px;
            z-index: 10;
        }

        .modal-backdrop.active {
            display: flex;
        }

        .modal-card {
            width: min(480px, 100%);
            background: white;
            border-radius: 24px;
            padding: 28px 28px 22px;
            box-shadow: 0 28px 80px rgba(15, 23, 42, 0.18);
        }

        .modal-card h3 {
            margin: 0 0 18px;
            font-size: 1.3rem;
            color: #0f172a;
        }

        .modal-field {
            display: grid;
            gap: 10px;
            margin-bottom: 18px;
        }

        .modal-field label {
            font-size: 0.95rem;
            color: #1f2937;
        }

        .modal-field input,
        .modal-field textarea {
            width: 100%;
            padding: 12px 14px;
            border-radius: 14px;
            border: 1px solid #cbd5e1;
            font-size: 0.98rem;
            outline: none;
        }

        .modal-controls {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 10px;
        }

        .button-secondary {
            background: #f1f5f9;
            border: none;
            color: #334155;
            padding: 12px 16px;
            border-radius: 14px;
            cursor: pointer;
        }

        @media (max-width: 620px) {
            .task-box {
                padding: 18px;
            }

            .modal-card {
                padding: 22px;
            }
        }
        /* Assistant styles */
        .assistant-button {
            display: none;
        }

        .assistant-panel {
            display: none;
            position: fixed;
            right: 22px;
            bottom: 92px;
            width: 360px;
            max-height: 72vh;
            background: white;
            border-radius: 14px;
            box-shadow: 0 28px 80px rgba(15,23,42,0.18);
            overflow: hidden;
            flex-direction: column;
            z-index: 60;
        }

        .assistant-panel.fullscreen {
            position: fixed;
            left: 0;
            right: 0;
            top: 0;
            bottom: 0;
            width: 100vw;
            height: 100vh;
            max-height: none;
            border-radius: 0;
            padding: 0;
            z-index: 1000;
        }

        .assistant-panel.active {
            display: flex;
        }

        .assistant-header {
            background: linear-gradient(90deg,#2563eb,#60a5fa);
            color: white;
            padding: 12px 14px;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 8px;
            justify-content: space-between;
        }

        .assistant-header .controls {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .assistant-header .fullscreen-toggle {
            background: rgba(255,255,255,0.12);
            border: none;
            color: white;
            padding: 6px 8px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 700;
        }

        .assistant-create-toggle {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.9rem;
            color: rgba(255,255,255,0.95);
        }

        .assistant-create-toggle input { width: 16px; height: 16px; }

        .assistant-messages {
            padding: 12px;
            overflow: auto;
            flex: 1 1 auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
            background: #f8fbff;
        }

        .assistant-input-row {
            display: flex;
            gap: 8px;
            padding: 12px;
            border-top: 1px solid #eef2ff;
            background: white;
        }

        .assistant-input-row input {
            flex: 1;
            padding: 10px 12px;
            border-radius: 10px;
            border: 1px solid #cbd5e1;
            outline: none;
        }

        .assistant-msg.user { align-self: flex-end; background:#2563eb; color:white; padding:8px 12px; border-radius:12px; }
        .assistant-msg.bot { align-self: flex-start; background:#eef7ff; color:#0f172a; padding:8px 12px; border-radius:12px; }

        .study-grid {
            display: grid;
            grid-template-columns: 260px minmax(0, 1fr);
            gap: 18px;
        }

        .study-sidebar {
            background: white;
            border: 1px solid #dbeafe;
            border-radius: 18px;
            padding: 18px;
            align-self: start;
        }

        .study-sidebar h3,
        .study-main h2 {
            margin: 0 0 12px;
        }

        .study-mode-buttons {
            display: grid;
            gap: 10px;
            margin: 16px 0;
        }

        .study-mode-button {
            padding: 11px 12px;
            border-radius: 12px;
            border: 1px solid #dbeafe;
            background: #f8fbff;
            color: #1f2937;
            font-weight: 700;
            cursor: pointer;
            text-align: left;
        }

        .study-mode-button.active {
            color: #1d4ed8;
            background: white;
            border-color: #93c5fd;
        }

        .study-main {
            background: white;
            border: 1px solid #dbeafe;
            border-radius: 18px;
            padding: 20px;
            min-height: 520px;
        }

        .study-panel {
            display: none;
        }

        .study-panel.active {
            display: block;
        }

        .study-chat-messages {
            height: 360px;
            overflow-y: auto;
            display: flex;
