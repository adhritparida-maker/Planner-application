                if (isSameDate(date, today)) {
                    dayCell.classList.add("today");
                }

                const dayNumber = document.createElement("div");
                dayNumber.className = "calendar-day-number";
                dayNumber.textContent = date.getDate();
                dayCell.appendChild(dayNumber);

                const actsOnDate = allActivities.filter(act => {
                    if (!act.dueDate) return false;
                    const due = parseLocalDate(act.dueDate);
                    due.setHours(0, 0, 0, 0);
                    return isSameDate(due, date);
                });
                const holidaysOnDate = getHolidaysOnDate(date);

                if (actsOnDate.length > 0 || holidaysOnDate.length > 0) {
                    const badges = document.createElement("div");
