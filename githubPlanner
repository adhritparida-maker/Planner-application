        function processAssistantCommands(text) {
            const allowed = assistantCreateToggle.checked;
            if (!allowed) return;
            const raw = String(text || '');

            function extractJSONWithItems(str) {
                // Try to locate the nearest JSON object that contains an "items" array.
                const itemsIndex = str.indexOf('"items"');
                if (itemsIndex !== -1) {
                    // find opening brace before itemsIndex
                    let start = str.lastIndexOf('{', itemsIndex);
                    if (start !== -1) {
                        // find matching closing brace
                        let depth = 0;
                        for (let i = start; i < str.length; i++) {
                            if (str[i] === '{') depth++;
                            else if (str[i] === '}') {
                                depth--;
                                if (depth === 0) {
                                    const candidate = str.slice(start, i + 1);
                                    try {
                                        const parsed = JSON.parse(candidate);
                                        if (parsed && Array.isArray(parsed.items)) return parsed;
                                    } catch (e) {
                                        // ignore
                                    }
                                    break;
                                }
                            }
                        }
                    }
                }

                // Fallback: try all curly-brace groups
                const regex = /{[^}]*}/g;
                let m;
                while ((m = regex.exec(str)) !== null) {
                    try {
                        const parsed = JSON.parse(m[0]);
                        if (parsed && Array.isArray(parsed.items)) return parsed;
                    } catch (e) {
                        // ignore
                    }
                }

                return null;
            }

            const parsed = extractJSONWithItems(raw);
            if (!parsed) {
                appendMessage('Assistant did not return a recognized create payload; no items were created.', 'bot');
                return;
            }

            const created = [];
            for (const item of parsed.items) {
                if (!item || !item.type || !item.tab || !item.text) continue;
                const type = item.type === 'Activity' ? 'Activity' : 'Task';
                const tab = item.tab === 'School' ? 'School' : 'Home';
                const dueDate = item.dueDate || '';
                const textBody = item.text;

                if (type === 'Activity') {
                    const act = { text: textBody, dueDate };
                    addActivityToTab(tab, act);
                    created.push({ type: 'Activity', tab, text: act.text, dueDate });
                } else {
                    const task = { text: textBody, dueDate, completed: false };
                    addTaskToTab(tab, task);
                    created.push({ type: 'Task', tab, text: task.text, dueDate });
                }
            }

            if (created.length > 0) {
                // Refresh UI where appropriate
                if (taskViews.includes(activeView)) displayTasks();
                if (activeView === 'Calendar') {
                    renderCalendar();
                    updateCalendarTasksList(selectedCalendarDate);
                }
                created.forEach(c => appendMessage(`Created ${c.type} in ${c.tab}: ${c.text} ${c.dueDate ? '(' + c.dueDate + ')' : ''}`, 'bot'));
            }
        }

        function appendMessage(text, who = 'bot') {
            const div = document.createElement('div');
            div.className = `assistant-msg ${who}`;
            div.textContent = text;
            assistantMessages.appendChild(div);
            assistantMessages.scrollTop = assistantMessages.scrollHeight;
        }

        async function askAssistant(prompt) {
            appendMessage(prompt, 'user');

            // Gather tasks context
            const all = loadAllTasks();
            const context = all.map(t => `${t.tab}: ${t.text}${t.dueDate ? ' (due ' + t.dueDate + ')' : ''}${t.completed ? ' [done]' : ''}`).join('\n');

            appendMessage('Thinking...', 'bot');

            // Replace with your GROQ API endpoint/key
            const GROQ_API_URL = 'https://api.groq.com/openai/v1/chat/completions';
            const GROQ_API_KEY = 'YOUR_API_KEY_HERE'; // <-- Paste your API key here

            if (!GROQ_API_KEY) {
                const thinking = assistantMessages.querySelector('.assistant-msg.bot:last-child');
                if (thinking) thinking.remove();
                appendMessage('No API key configured. Open Planner.html and paste your key at the line: GROQ_API_KEY = ""', 'bot');
                return;
            }

            try {
                const systemMsg = 'You are a helpful planner assistant. The user has the following tasks:\n\n' + context + '\n\nHelp them manage and organize their tasks. If the user asks you to create or schedule a task or activity, answer naturally and also append a single JSON object at the end of your reply with the structure {"items":[{"type":"Activity","tab":"Home","dueDate":"YYYY-MM-DD","text":"..."}]}. If there is nothing to create, the JSON should be {"items":[]}. Use exact values Task or Activity for type and School or Home for tab. Do not add any extra text inside the JSON object.';
                const body = {
                    model: 'llama-3.3-70b-versatile',
                    messages: [
                        { role: 'system', content: systemMsg },
                        { role: 'user', content: prompt }
                    ],
                    temperature: 0.7,
                    max_tokens: 1000
                };
                console.debug('GROQ request', GROQ_API_URL, body);

                const res = await fetch(GROQ_API_URL, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${GROQ_API_KEY}`
                    },
                    body: JSON.stringify(body)
                });

                const thinking = assistantMessages.querySelector('.assistant-msg.bot:last-child');
                if (thinking) thinking.remove();

                if (!res.ok) {
                    let text = '';
                    try { text = await res.text(); } catch (e) { text = '(no response body)'; }
                    appendMessage(`GROQ API error ${res.status}: ${text}`, 'bot');
                    console.error('GROQ error', res.status, text);
                    return;
                }

                const json = await res.json();
                const answer = json.choices?.[0]?.message?.content || JSON.stringify(json, null, 2);
                appendMessage(answer, 'bot');
                // If user has allowed assistant to create items, parse commands
                try {
                    processAssistantCommands(answer);
                } catch (e) {
                    console.warn('Processing assistant commands failed', e);
                }
            } catch (err) {
                const thinking = assistantMessages.querySelector('.assistant-msg.bot:last-child');
                if (thinking) thinking.remove();
                appendMessage('Network error contacting GROQ API. This may be CORS or file:// origin blocking; run the page on a local server or use a server-side proxy. See console for details.', 'bot');
                console.error('GROQ request failed', err);
            }
        }

        assistantSend.addEventListener('click', () => {
            const val = assistantInput.value.trim();
            if (!val) return;
            assistantInput.value = '';
            askAssistant(val);
        });

        assistantInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                assistantSend.click();
            }
        });
    </script>
</body>
</html>
