                type: studyCurrentType
            } : getStudyQuestionSettings();

            if (!settings.topic) {
                status.textContent = 'Please enter a topic first.';
                return;
            }

            studyCurrentTopic = settings.topic;
            studyCurrentSubject = settings.subject;
            studyCurrentDifficulty = settings.difficulty;
            studyCurrentType = settings.type;
