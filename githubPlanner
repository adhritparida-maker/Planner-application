        function triggerReminder(reminder, isTest = false) {
            const usesPopup = reminder.alertType === 'popup' || reminder.alertType === 'both';
            const usesSound = reminder.alertType === 'sound' || reminder.alertType === 'both';

            if (!isTest) {
                reminder.fired = true;
                saveReminders();
                displayReminders();
            }

            if (usesPopup) {
                showReminderAlert(reminder);
            } else if (usesSound) {
                showReminderSoundBar(reminder);
            }

            if (usesSound) {
                playReminderSound();
                stopReminderSoundLoop();
                reminderSoundInterval = setInterval(playReminderSound, 3000);
            }

            sendBrowserNotification(reminder);
        }

