        async function callStudyAI(messages, temperature = 0.7) {
            if (!STUDY_GROQ_API_KEY) {
                throw new Error('No Groq API key is configured for the study app.');
            }

            const response = await fetch(STUDY_GROQ_API_URL, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${STUDY_GROQ_API_KEY}`
                },
                body: JSON.stringify({
                    model: STUDY_MODEL,
                    messages,
                    temperature,
                    max_tokens: 1200
                })
            });

            if (!response.ok) {
                let detail = '';
                try { detail = await response.text(); } catch (error) { detail = 'No response body.'; }
                throw new Error(`Groq API error ${response.status}: ${detail}`);
            }

            const data = await response.json();
            return data.choices?.[0]?.message?.content || '';
        }

